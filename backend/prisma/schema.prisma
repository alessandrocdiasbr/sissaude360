datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Unidade {
  id          String     @id @default(uuid())
  nome        String     @unique
  tipo        String     @default("UBS")
  endereco    String?
  telefone    String?
  producoes   Producao[]
  estoques    Estoque[]
  servidores  Servidor[]

  // Fila (Manchester)
  tickets     Ticket[]
  salas       Sala[]
}

model Servidor {
  id                String   @id @default(uuid())
  nome              String
  telefone          String?
  email             String?
  funcao            String
  formaContratacao  String   // Concurso, Processo Seletivo, Contrato Temporário, Comissão
  unidadeId         String
  unidade           Unidade  @relation(fields: [unidadeId], references: [id])
}

model Item {
  id             String         @id @default(uuid())
  nome           String
  descricao      String?
  categoria      String         // Papelaria, Curativo, Instrumental, etc.
  unidadeMedida  String         // Unidade, Frasco, Caixa, etc.
  estoques       Estoque[]
  movimentacoes  Movimentacao[]
}

model Estoque {
  id         String   @id @default(uuid())
  itemId     String
  unidadeId  String?  // Null se for Almoxarifado Central
  quantidade Float    @default(0)
  item       Item     @relation(fields: [itemId], references: [id])
  unidade    Unidade? @relation(fields: [unidadeId], references: [id])

  @@unique([itemId, unidadeId])
}

model Movimentacao {
  id             String   @id @default(uuid())
  itemId         String
  unidadeId      String?
  tipo           String   // ENTRADA, SAIDA, TRANSFERENCIA
  quantidade     Float
  data           DateTime @default(now())
  observacao     String?
  item           Item     @relation(fields: [itemId], references: [id])
}

model Indicador {
  id          String     @id @default(uuid())
  nome        String     @unique
  peso        Float?     @default(1.0)
  categoria   String?
  metaRegular Float      @default(30)
  metaBom     Float      @default(60)
  metaOtimo   Float      @default(90)
  producoes   Producao[]
}

model Producao {
  id           String    @id @default(uuid())
  unidadeId    String
  indicadorId  String
  mes          Int
  ano          Int
  numerador    Float
  denominador  Float
  pontuacao    Float     // (numerador / denominador) * 100
  unidade      Unidade   @relation(fields: [unidadeId], references: [id])
  indicador    Indicador @relation(fields: [indicadorId], references: [id])

  @@unique([unidadeId, indicadorId, mes, ano])
}

model Usuario {
  id       String @id @default(uuid())
  nome     String
  email    String @unique
  senha    String
}

model Ticket {
  id           String   @id @default(uuid())
  senha        String              // Ex: "A001", "P023"
  tipo         String              // NORMAL, PRIORITARIO
  risco        String   @default("VERDE")  // VERMELHO, LARANJA, AMARELO, VERDE, AZUL, BRANCO
  status       String   @default("AGUARDANDO")  // AGUARDANDO, CHAMADO, EM_ATENDIMENTO, FINALIZADO

  unidadeId    String
  unidade      Unidade  @relation(fields: [unidadeId], references: [id])

  salaId       String?
  sala         Sala?    @relation(fields: [salaId], references: [id])

  criadoEm     DateTime @default(now())
  chamadoEm    DateTime?
  finalizadoEm DateTime?
}

model Sala {
  id         String   @id @default(uuid())
  numero     String              // Ex: "Sala 1", "Guichê 3"
  tipo       String   @default("CONSULTA")
  ativo      Boolean  @default(true)

  unidadeId  String
  unidade    Unidade  @relation(fields: [unidadeId], references: [id])

  tickets    Ticket[]
}
