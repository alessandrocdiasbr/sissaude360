# Configurações do Banco de Dados
# Exemplo local (crie o banco sissaude360 antes do migrate — ver scripts/sql/create-database.sql)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/sissaude360

# Segurança e Autenticação
# Gere uma string aleatória longa para o segredo JWT
JWT_SECRET=gere-uma-string-aleatoria-longa-aqui

# Configurações do Servidor
PORT=3001

# Integrações Externas
TRANSPARENCIA_API_KEY=sua-chave-aqui

# Configurações de Localidade
# Ex: 3106200 para Belo Horizonte (MG)
MUNICIPIO_IBGE_PADRAO=3106200

# Segurança CORS (Separe por vírgula se houver mais de uma origem)
CORS_ORIGIN=http://localhost:5173,https://sissaude360.railway.app
